<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements applied to the bundled command-line helpers (yt-dlp, ffmpeg)
  when re-signing them under the Hardened Runtime for notarization.

  yt-dlp_macos is a PyInstaller bundle: it writes & executes code at runtime and
  relies on DYLD environment variables, so it needs the JIT / unsigned-memory /
  dyld-env exceptions. ffmpeg loads its own dylibs, hence library-validation is
  disabled. These exceptions apply ONLY to the helper binaries, not the main app.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
